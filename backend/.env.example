# ─── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
# For MongoDB Atlas (production):
# MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/
DB_NAME=glaucoma_monitor

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_32_char_string

# ─── ESP32 Serial Port ────────────────────────────────────────────────────────
# macOS:   /dev/tty.usbserial-XXXX  or  /dev/cu.SLAB_USBtoUART
# Linux:   /dev/ttyUSB0
# Windows: COM3
# Cloud:   DISABLED
SERIAL_PORT=/dev/tty.usbserial-0001
BAUD_RATE=115200

# ─── Hospital Branding ────────────────────────────────────────────────────────
HOSPITAL_NAME=GlaucoMonitor Clinic

# ─── Alert Settings ───────────────────────────────────────────────────────────
IOP_ALERT_THRESHOLD=21
READ_INTERVAL_SECONDS=5

# ─── Email Alerts (Gmail) ─────────────────────────────────────────────────────
ALERT_EMAIL=
ALERT_EMAIL_PASSWORD=

# ─── Twilio SMS + WhatsApp ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
DOCTOR_PHONE_NUMBER=

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
